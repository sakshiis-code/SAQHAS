# SAQHAS Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is in .gitignore.

# ── External APIs ────────────────────────────────────────────────────────────
# OpenWeatherMap (free tier): https://openweathermap.org/api/air-pollution
OWM_API_KEY=your_openweathermap_api_key_here

# IQAir AirVisual (free community tier): https://www.iqair.com/air-pollution-data-api
IQAIR_API_KEY=your_iqair_api_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas free M0 cluster connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/saqhas

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Email (Nodemailer via Gmail SMTP) ─────────────────────────────────────────
# Enable "App Passwords" in your Google Account settings to get GMAIL_APP_PASSWORD
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Push Notifications (VAPID) ───────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ── Services ─────────────────────────────────────────────────────────────────
# URL of the Flask ML microservice (deployed on Render)
ML_SERVICE_URL=https://saqhas-ml.onrender.com

# Frontend URL for CORS whitelist
FRONTEND_URL=https://saqhas.vercel.app

# Port (Render sets this automatically)
PORT=5000
